---
import { getRelativeLocaleUrl } from "astro:i18n";
import LanguagePicker from "./LanguagePicker.astro";
import Wrapper from "./Wrapper.astro";
import siteData from "../data/site.json";

interface Props {
  locale: string;
}

import features from "../data/features.json";

const { locale } = Astro.props;
let navLinks = siteData.nav[locale as keyof typeof siteData.nav];

const isEs = locale === "es";
---

<nav
  id="main-nav"
  class="fixed w-full z-50 top-0 start-0 border-b bg-transparent border-transparent transition-all duration-300 ease-in-out"
>
  <Wrapper>
    <div class="flex items-center justify-between py-3">
      <!-- Logo -->
      <a
        href={getRelativeLocaleUrl(locale, "/")}
        class="flex items-center gap-2"
      >
        <img src="/khipu_logo.png" alt="Logo" class="w-64 h-16" />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="nav-link text-sm font-medium transition-colors hover:text-primary-400"
            >
              {link.label}
            </a>
          ))
        }
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <LanguagePicker locale={locale} />
        <a
          href="mailto:contact@aimaralab.com"
          class="hidden sm:inline-flex items-center px-4 py-2 text-sm font-medium bg-primary-500 hover:bg-primary-600 rounded-full transition-colors shadow-lg shadow-primary-500/25 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 focus:ring-offset-black text-gray-800"
        >
          {isEs ? "Apóyanos" : "Support Us"}
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          type="button"
          class="md:hidden p-2 nav-link hover:text-gray-200"
          aria-label="Open menu"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </Wrapper>

  <!-- Mobile Navigation -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-gray-800 bg-black"
  >
    <div class="px-4 py-4 space-y-3">
      {
        navLinks.map((link) => (
        <a
          href={link.href}
          class="nav-link block text-base font-medium py-2 hover:text-primary-500"
        >
          {link.label}
        </a>
        ))
      }
      <a
        href="mailto:contact@aimaralab.com"
        class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-white bg-primary-500 hover:bg-primary-600 rounded-full transition-colors mt-4 text-center w-full"
      >
        {isEs ? "Apóyanos" : "Support Us"}
      </a>
    </div>
  </div>
</nav>

<script is:inline>
  const menuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const mainNav = document.getElementById("main-nav");

  // Mobile menu toggle
  menuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  // Sticky transparent-to-black navbar logic
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      // Scrolled down: add glassmorphic black background
      mainNav?.classList.remove("bg-transparent", "border-transparent");
      mainNav?.classList.add(
        "bg-black/95",
        "backdrop-blur-md",
        "border-gray-800",
        "is-scrolled"
      );
    } else {
      // Top of page: transparent
      mainNav?.classList.remove(
        "bg-black/95",
        "backdrop-blur-md",
        "border-gray-800",
        "is-scrolled"
      );
      mainNav?.classList.add("bg-transparent", "border-transparent");
    }
  });
</script>

<style>
  /* Header text color logic */
  .nav-link {
    color: white; /* text-white */
    transition: color 0.3s ease;
  }

  #main-nav.is-scrolled .nav-link {
    color: #d1d5db; /* text-gray-300 */
  }

  #main-nav.is-scrolled .nav-link:hover {
    color: #ff743f; /* text-primary-400 - using hex for robustness */
  }

  /* Handle LanguagePicker children */
  #main-nav:not(.is-scrolled) :global(.lang-link span) {
     color: rgba(255, 255, 255, 0.9);
  }
  
  #main-nav.is-scrolled :global(.lang-link) {
     color: #d1d5db;
  }
  
  #main-nav:not(.is-scrolled) :global(.lang-link) {
     color: white;
  }
</style>
