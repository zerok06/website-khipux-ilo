---
import Wrapper from "./Wrapper.astro";
import heroData from "../data/hero.json";
import siteData from "../data/site.json";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const content = heroData[locale as keyof typeof heroData];
const isEs = locale === "es";

const backgroundSymbols = [
  "/images/patterns/symbol1.svg",
  "/images/patterns/symbol2.svg",
  "/images/patterns/symbol1.svg",
  "/images/patterns/symbol2.svg",
];
---

<section
  class="relative min-h-dvh flex items-center justify-center bg-black bg-cover bg-center overflow-hidden pt-32 pb-12"
  style="background-image: url('/venue/3-ciudad.jpg');"
>
  <!-- Overlays & Atmosphere -->
  <div
    class="absolute inset-0 bg-linear-to-b from-black/20 via-black/60 to-black z-0 pointer-events-none"
  >
  </div>

  <!-- Glowing Orbs inside the atmosphere -->
  <div
    class="absolute top-1/4 left-1/4 w-[30vh] h-[30vh] bg-primary-500/20 rounded-full blur-[100px] animate-orb-pulse z-0 pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-1/4 right-1/4 w-[40vh] h-[40vh] bg-primary-600/10 rounded-full blur-[120px] animate-orb-pulse-slow z-0 pointer-events-none"
  >
  </div>

  <Wrapper
    class="relative z-10 w-full flex flex-col items-center justify-center text-center px-4"
  >
    <div
      class="max-w-5xl mx-auto space-y-3 md:space-y-5 animate-slide-in-up flex flex-col items-center"
    >
      <!-- Event Badge (Pill) -->
      <div class="animate-fade-in flex items-center justify-center gap-4">
        <div
          class="backdrop-blur-xl bg-white px-6 py-1 rounded-full shadow-[0_4px_30px_rgba(0,0,0,0.1)] transition-transform hover:scale-105"
        >
          <span
            class="bg-clip-text text-transparent bg-linear-to-r from-primary-400 to-primary-600 text-xs tracking-widest uppercase font-black"
          >
            {content.event_type}
          </span>
        </div>
      </div>

      <!-- Title (Monolithic & Vibrant) -->
      <div class="flex flex-col items-center">
        <h1
          class="text-2xl sm:text-3xl md:text-4xl lg:text-[3.5rem] font-semibold text-white leading-tight tracking-tighter drop-shadow-2xl"
        >
          KHIPU<span
            class="text-transparent bg-clip-text bg-linear-to-b from-primary-400 to-primary-600"
            >x</span
          > Ilo
        </h1>
        <div
          class="w-24 md:w-40 h-0.5 md:h-1 bg-linear-to-r from-transparent via-primary-500 to-transparent mt-4 md:mt-8 rounded-full opacity-80 shadow-[0_0_20px_rgba(241,91,36,0.5)]"
        >
        </div>
      </div>

      <!-- Subtitle -->
      <p
        class="text-base md:text-lg text-gray-200 max-w-3xl leading-relaxed drop-shadow-md font-normal"
      >
        {content.description}
      </p>

      <!-- Event Info (Glass Pills) -->
      <div
        class="flex flex-wrap justify-center gap-4 text-sm md:text-base font-medium mt-4"
      >
        <div
          class="flex items-center gap-3 text-white backdrop-blur-md bg-black/40 px-6 py-3 rounded-2xl border border-white/10 shadow-lg transition-colors hover:bg-black/60"
        >
          <svg
            class="w-5 h-5 text-primary-500"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
            ></path>
          </svg>
          <span class="tracking-wide text-gray-200"
            >{isEs ? "18-19 Agosto, 2026" : "Aug 18-19, 2026"}</span
          >
        </div>
        <div
          class="flex items-center gap-3 text-white backdrop-blur-md bg-black/40 px-6 py-3 rounded-2xl border border-white/10 shadow-lg transition-colors hover:bg-black/60"
        >
          <svg
            class="w-5 h-5 text-primary-500"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
            ></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          <span class="tracking-wide text-gray-200"
            >{isEs ? "Ilo, Perú" : "Ilo, Peru"}</span
          >
        </div>
      </div>

      <!-- Call to Action Buttons -->
      <div
        class="flex flex-wrap justify-center gap-4 sm:gap-6 pt-2 w-full max-w-lg"
      >
        <a
          href={isEs ? "/es/register" : "/en/register"}
          class="group relative inline-flex items-center justify-center gap-2 px-6 py-2 bg-primary-500 text-white rounded-full font-bold text-lg transition-all duration-300 shadow-[0_0_20px_rgba(241,91,36,0.4)] hover:shadow-[0_0_40px_rgba(241,91,36,0.6)] w-full sm:w-auto overflow-hidden"
        >
          <!-- Shimmer effect -->
          <div
            class="absolute inset-0 -translate-x-full bg-linear-to-r from-transparent via-white/20 to-transparent group-hover:animate-shimmer pointer-events-none"
          >
          </div>
          <span class="relative z-10">{content.cta_primary}</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="relative z-10 w-5 h-5 transition-transform group-hover:translate-x-1"
            ><path d="m9 18 6-6-6-6"></path></svg
          >
        </a>

        <a
          href={isEs ? "/es/schedule" : "/en/schedule"}
          class="inline-flex items-center justify-center px-6 py-2 bg-white/5 border border-white/20 backdrop-blur-sm text-white rounded-full font-bold text-lg transition-all duration-300 hover:bg-white/10 hover:border-white/40 w-full sm:w-auto shadow-lg"
        >
          {content.cta_secondary}
        </a>
      </div>

      <!-- Stats Row (Floating Glass Cards) -->
      <div class="pt-1 md:pt-2 w-full max-w-4xl">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-6">
          {
            content.stats.map(
              (stat: { value: string; label: string }, index: number) => (
                <div
                  class="animate-fade-in-up flex flex-col items-center justify-center p-4 rounded-2xl backdrop-blur-xl bg-white/5 border border-white/10 shadow-[0_8px_32px_rgba(0,0,0,0.3)] transition-all duration-500 hover:bg-white/10 hover:-translate-y-2 hover:border-primary-500/30 group"
                  style={`animation-delay: ${index * 0.15 + 0.5}s`}
                >
                  <div class="text-xl md:text-2xl font-black bg-clip-text text-transparent bg-linear-to-br from-white to-gray-400 font-heading tracking-tight mb-1 md:mb-2 group-hover:from-white group-hover:to-primary-200 transition-all duration-500 drop-shadow-lg">
                    {stat.value}
                  </div>
                  <div class="text-xs text-primary-400 uppercase tracking-[0.1rem] font-bold text-center">
                    {stat.label}
                  </div>
                </div>
              ),
            )
          }
        </div>
      </div>
    </div>
  </Wrapper>
</section>

<style>
  /* Custom Keyframes for Modern Polish */
  .animate-slide-in-up {
    animation: slide-in-up 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes slide-in-up {
    0% {
      opacity: 0;
      transform: translateY(40px) scale(0.98);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .animate-fade-in {
    opacity: 0;
    animation: fade-in 1.5s ease-out 0.3s forwards;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .animate-fade-in-up {
    opacity: 0;
    animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fade-in-up {
    0% {
      opacity: 0;
      transform: translateY(30px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-orb-pulse {
    animation: orb-pulse 8s ease-in-out infinite alternate;
  }

  .animate-orb-pulse-slow {
    animation: orb-pulse 12s ease-in-out infinite alternate-reverse;
  }

  @keyframes orb-pulse {
    0% {
      transform: scale(0.8) translate(0, 0);
      opacity: 0.5;
    }
    100% {
      transform: scale(1.2) translate(5%, 5%);
      opacity: 0.8;
    }
  }

  @keyframes shimmer {
    100% {
      transform: translateX(100%);
    }
  }
</style>
